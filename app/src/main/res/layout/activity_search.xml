<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Заголовок с иконкой назад -->

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/tbSearch"
        style="@style/TitleIcBack"
        app:title="@string/search"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_l"
        android:layout_marginEnd="@dimen/spacing_l"
        android:layout_gravity="center_vertical"
        android:background="@drawable/search_edit_text_background">

        <!-- поле поиского запроса -->
        <EditText
            android:id="@+id/searchEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/spacing_xxxl"
            android:paddingVertical="@dimen/spacing_m"
            android:background="@android:color/transparent"
            android:hint="@string/search"
            android:inputType="text"
            android:maxLines="1"
            android:textColor="@color/black"
            android:textColorHint="?attr/searchTint"
            android:textSize="@dimen/text_size_body"
            android:textCursorDrawable="@null"
            android:fontFamily="@font/ys_display_regular"/>

        <!--иконка лупа-->
        <ImageView
            style="@style/Icon"
            android:src="@drawable/ic_search_16"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="@dimen/spacing_m"
            app:tint="?attr/searchTint"/>

        <!--очистка иконка-->

        <ImageView
            android:id="@+id/clearButton"
            style="@style/Icon"
            android:layout_gravity="center_vertical|end"
            android:src="@drawable/ic_clear_16"
            android:layout_marginEnd="@dimen/spacing_m"
            app:tint="?attr/searchTint"
            android:visibility="gone"
            tools:visibility="visible"
            tools:ignore="ContentDescription"/>

    </FrameLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTracks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/spacing_xxl"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
</LinearLayout>